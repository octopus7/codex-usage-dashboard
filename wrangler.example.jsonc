{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "codex-usage-dashboard",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-18",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true
  }

  // `npm run setup:db`를 실행하면 d1_databases 설정이 이 파일에 자동 추가됩니다.
}
