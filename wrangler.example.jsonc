{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "codex-usage-dashboard",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-18",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "codex-usage-db",
      "database_id": "__D1_DATABASE_ID__"
    }
  ],
  "observability": {
    "enabled": true
  }
}
